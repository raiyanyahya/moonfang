{
  "name": "moonfang-castle",
  "version": "1.0.0",
  "description": "Moonfang Castle - a gothic roguelike action platformer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux",
    "build:web": "bash tools/build-web.sh",
    "deploy": "npm run build:web && npx wrangler pages deploy web-dist --project-name moonfang-castle"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.moonfang.castle",
    "productName": "Moonfang Castle",
    "files": [
      "index.html",
      "main.js",
      "icon.png",
      "js/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Game",
      "icon": "icon.png",
      "maintainer": "moonfang@example.com"
    }
  }
}